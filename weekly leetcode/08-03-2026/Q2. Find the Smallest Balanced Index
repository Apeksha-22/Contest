class Solution {
public:
    int smallestBalancedIndex(vector<int>& nums) {
        int n = nums.size();
        
        vector<long long> pre(n);
        pre[0] = nums[0];
        for (int i = 1; i < n; i++)
            pre[i] = pre[i-1] + nums[i];

        const long long LIM = 100000000000000LL;
        long long prod = 1;

        for (int i = n - 1; i >= 0; i--) {
            long long left = (i == 0 ? 0 : pre[i - 1]);
            if (left == prod) return i;

            if (i > 0) {
                if (prod > LIM / nums[i]) prod = LIM;
                else prod *= nums[i];
            }
        }

        return -1;
    }
};

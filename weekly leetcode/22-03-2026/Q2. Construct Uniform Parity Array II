class Solution {
public:
    bool uniformArray(vector<int>& nums1) {
        int mn = *min_element(nums1.begin(), nums1.end());
        
        if (mn % 2 == 0) {
            for (int x : nums1)
                if (x % 2 == 1)
                    return false;
            return true;
        }

        int smod = mn;

        for (int x : nums1) {
            if (x % 2 == 0) {
                if (smod >= x)
                    return false;
            }
        }

        return true;
    }
};
